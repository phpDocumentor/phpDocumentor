<dt class="phpdocumentor-table-of-contents__entry -{{ type }} -{{ node.visibility }}">
    <a class="{% if node.deprecated %}-deprecated{% endif %}" href="{{ link(node) }}">{{ node is property ? '$' }}{{ node.name }}{{ node is method or node is function ? '()' }}</a>
    <span>
        {% if node is constant %}{% set constantValueMaxLength = 50 %}&nbsp;: {{ node.type ? node.type|route('class:short')|join('|')|raw : 'mixed' }}&nbsp;= {% set constantValue = (node.value ~ '')|replace({'\r': '', '\n': ' '})|trim %}{{ constantValue|length > constantValueMaxLength ? constantValue|slice(0, constantValueMaxLength - 3) ~ '...' : constantValue }}{% endif %}
        {% if node is enumCase %}{% if node.value %}&nbsp;= {{ node.value }}{% endif %}{% endif %}
        {% if node is property %}&nbsp;: {{ node.type ? node.type|route('class:short')|join('|')|raw : 'mixed' }}{% endif %}
        {% if node is method or node is function %}&nbsp;: {{ node.response.type|route('class:short')|join('|')|raw }}{% endif %}
    </span>
</dt>
{% if node.summary %}
<dd>{{ node.summary }}</dd>
{% endif %}
